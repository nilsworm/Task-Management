# =============================================================
# LOKAL (docker compose up)
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================

# --- Datenbank ---
POSTGRES_DB=taskmanager
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=taskmanager
POSTGRES_PORT=5432

# --- pgAdmin (nur lokal) ---
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Backend ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- AI Provider ---
# "ollama" (default, lokal) oder "openrouter"
AI_PROVIDER=ollama
# Nur bei openrouter: API Key von https://openrouter.ai/keys
AI_API_KEY=
# Modell-Override (leer = Provider-Default wird verwendet)
# Beispiele OpenRouter free models:
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemma-3-27b-it:free
#   qwen/qwen3-30b-a3b:free
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Banking/Finance ---
# Comma-separated IBANs of your own bank accounts.
# Used to detect inter-account transfers (TRANSFER type) and skip the receiving side.
# Example: OWN_ACCOUNT_IBANS=DE80760300800270566776,DE44100123450409695601
OWN_ACCOUNT_IBANS=

# --- Frontend (Dockerized lokal) ---
FRONTEND_PORT=5174


# =============================================================
# PRODUKTION (Coolify → Environment Variables)
# Diese Werte NICHT in .env committen — in Coolify als Secrets
# eintragen. Befehle zum Generieren stehen unten.
# =============================================================

# --- Datenbank ---
# POSTGRES_DB=taskmanager
# POSTGRES_USER=tm_prod
# POSTGRES_PASSWORD=<openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32>

# --- Backend ---
# CORS_ORIGINS=https://<deine-domain.example.com>

# --- Traefik / Domain ---
# DOMAIN=tasks.example.com

# --- Basic Auth (Traefik) ---
# Generieren: htpasswd -nb admin deinpasswort
# Dann JEDEN $ durch $$ ersetzen, bevor du es in Coolify einträgst.
# Beispiel: admin:$apr1$xyz$abc  →  admin:$$apr1$$xyz$$abc
# BASIC_AUTH_USERS=admin:$$apr1$$...
